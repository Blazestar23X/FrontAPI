# FlowCall Configuration
PORT=3000

# Database
DATABASE_PATH=./data/flowcall.db

# Twilio (Voice + SMS)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# Email (SendGrid or Resend)
# For SendGrid:
SENDGRID_API_KEY=your_sendgrid_api_key
# For Resend:
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM_ADDRESS=noreply@flowcall.app

# Default plumber/company to notify
DEFAULT_COMPANY_NAME="Emergency Plumbing Co."
DEFAULT_COMPANY_PHONE=+15559876543
DEFAULT_COMPANY_EMAIL=plumber@example.com